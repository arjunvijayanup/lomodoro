{
    "manifest_version": 3,
    "name": "Lomodoro",
    "version": "1.0.0",
    "minimum_chrome_version": "109",
    "description": "Pomodoro timer with built-in lofi stream.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icons/icon48.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "alarms",
        "notifications",
        "offscreen"
    ],
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
